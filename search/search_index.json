{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u540d","text":"<p>\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306e\u6982\u8981\u3092\u3053\u3053\u306b\u66f8\u3044\u3066\u304f\u3060\u3055\u3044\u3002</p>"},{"location":"#_2","title":"\u6982\u8981","text":""},{"location":"#_3","title":"\u95a2\u9023\u30ea\u30f3\u30af","text":""},{"location":"guide/add-doc/","title":"\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u306e\u8ffd\u52a0\u65b9\u6cd5","text":""},{"location":"guide/add-doc/#_2","title":"\u624b\u9806","text":""},{"location":"guide/add-doc/#1-markdown","title":"1. Markdown \u30d5\u30a1\u30a4\u30eb\u3092\u4f5c\u6210","text":"<p><code>docs/</code> \u4ee5\u4e0b\u306e\u4efb\u610f\u306e\u5834\u6240\u306b Markdown \u30d5\u30a1\u30a4\u30eb\u3092\u4f5c\u6210\u3057\u307e\u3059\u3002</p> <pre><code># \u4f8b\uff1a\u65b0\u3057\u3044\u30ac\u30a4\u30c9\u30da\u30fc\u30b8\ntouch docs/guide/my-page.md\n</code></pre>"},{"location":"guide/add-doc/#2-mkdocsyml-nav","title":"2. mkdocs.yml \u306e nav \u306b\u8ffd\u52a0","text":"<p><code>mkdocs.yml</code> \u306e <code>nav</code> \u30bb\u30af\u30b7\u30e7\u30f3\u306b\u30da\u30fc\u30b8\u3092\u8ffd\u52a0\u3057\u307e\u3059\uff1a</p> <pre><code>nav:\n  - Home: index.md\n  - \u30ac\u30a4\u30c9:\n    - \u30bb\u30c3\u30c8\u30a2\u30c3\u30d7: guide/setup.md\n    - \u65b0\u3057\u3044\u30da\u30fc\u30b8: guide/my-page.md  # \u2190 \u8ffd\u52a0\n  - Slides: slides/index.md\n</code></pre>"},{"location":"guide/add-doc/#3","title":"3. \u30ed\u30fc\u30ab\u30eb\u3067\u78ba\u8a8d","text":"<pre><code>uv run mkdocs serve\n</code></pre>"},{"location":"guide/add-doc/#_3","title":"\u6ce8\u610f\u4e8b\u9805","text":""},{"location":"guide/add-doc/#_4","title":"\u7de8\u96c6\u7981\u6b62\u306e\u30d5\u30a1\u30a4\u30eb","text":"<p>\u4ee5\u4e0b\u306e\u30d5\u30a1\u30a4\u30eb\u306f\u81ea\u52d5\u751f\u6210\u3055\u308c\u308b\u305f\u3081\u76f4\u63a5\u7de8\u96c6\u3057\u306a\u3044\u3067\u304f\u3060\u3055\u3044\uff1a</p> \u30d5\u30a1\u30a4\u30eb \u751f\u6210\u5143 <code>docs/slides/index.md</code> <code>hooks/slides_index.py</code> <code>docs/slides/&lt;name&gt;/index.html</code> <code>slides/scripts/build-local.sh</code> / CI"},{"location":"guide/add-doc/#_5","title":"\u7d75\u6587\u5b57\u306e\u4f7f\u3044\u65b9","text":"<p>Unicode \u7d75\u6587\u5b57\u3092\u305d\u306e\u307e\u307e\u66f8\u304f\u3053\u3068\u304c\u3067\u304d\u307e\u3059\uff1a</p> <pre><code># \ud83d\ude80 \u30bf\u30a4\u30c8\u30eb\n\n\u5185\u5bb9 \ud83c\udf89\n</code></pre> <p>Markdown \u62e1\u5f35\u306e twemoji \u3082\u5229\u7528\u3067\u304d\u307e\u3059\uff08<code>mkdocs.yml</code> \u3067\u8a2d\u5b9a\u6e08\u307f\uff09\uff1a</p> <pre><code>:rocket: \u30bf\u30a4\u30c8\u30eb\n</code></pre>"},{"location":"guide/add-doc/#material","title":"Material \u30c6\u30fc\u30de\u306e\u6a5f\u80fd","text":"<p>\u3053\u306e\u30b5\u30a4\u30c8\u306f MkDocs Material \u30c6\u30fc\u30de\u3092\u4f7f\u7528\u3057\u3066\u3044\u307e\u3059\u3002 \u4ee5\u4e0b\u306e\u8a18\u6cd5\u304c\u4f7f\u7528\u3067\u304d\u307e\u3059\uff1a</p> <pre><code>!!! note \"\u30e1\u30e2\"\n    \u6ce8\u91c8\u30dc\u30c3\u30af\u30b9\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002\n\n!!! warning \"\u8b66\u544a\"\n    \u8b66\u544a\u30dc\u30c3\u30af\u30b9\u304c\u8868\u793a\u3055\u308c\u307e\u3059\u3002\n</code></pre>"},{"location":"guide/add-slide/","title":"\u30b9\u30e9\u30a4\u30c9\u306e\u8ffd\u52a0\u65b9\u6cd5","text":""},{"location":"guide/add-slide/#_2","title":"\u624b\u9806","text":""},{"location":"guide/add-slide/#1","title":"1. \u30c6\u30f3\u30d7\u30ec\u30fc\u30c8\u3092\u30b3\u30d4\u30fc","text":"<pre><code>cp -r slides/src/slides/_template slides/src/slides/&lt;\u30d5\u30a9\u30eb\u30c0\u540d&gt;\n</code></pre> <p>\u30d5\u30a9\u30eb\u30c0\u540d\u306f\u30b9\u30e9\u30a4\u30c9\u306e\u8b58\u5225\u5b50\u306b\u306a\u308a\u307e\u3059\uff08\u82f1\u6570\u5b57\u30fb\u30cf\u30a4\u30d5\u30f3\u63a8\u5968\uff09\u3002</p>"},{"location":"guide/add-slide/#2-contentmd","title":"2. content.md \u3092\u7de8\u96c6","text":"<p><code>slides/src/slides/&lt;\u30d5\u30a9\u30eb\u30c0\u540d&gt;/content.md</code> \u3092\u958b\u3044\u3066\u7de8\u96c6\u3057\u307e\u3059\u3002</p> <p>frontmatter \u306e\u5fc5\u9808\u9805\u76ee:</p> <pre><code>---\nmarp: true\ntheme: blue-theme\nclass: lead\npaginate: true\ntitle: \u30b9\u30e9\u30a4\u30c9\u306e\u30bf\u30a4\u30c8\u30eb   # \u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u30b5\u30a4\u30c8\u306e\u4e00\u89a7\u306b\u8868\u793a\u3055\u308c\u308b\ndate: 2026-01-01           # \u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u30b5\u30a4\u30c8\u306e\u4e00\u89a7\u306b\u8868\u793a\u3055\u308c\u308b\n---\n</code></pre> <p><code>title</code> \u3068 <code>date</code> \u304c\u6b20\u3051\u308b\u3068\u4e00\u89a7\u30da\u30fc\u30b8\u306b\u6b63\u3057\u304f\u8868\u793a\u3055\u308c\u307e\u305b\u3093\u3002</p>"},{"location":"guide/add-slide/#3","title":"3. \u30b9\u30e9\u30a4\u30c9\u3092\u533a\u5207\u308b","text":"<p>\u30da\u30fc\u30b8\u306e\u533a\u5207\u308a\u306f <code>---</code> \u3067\u884c\u3044\u307e\u3059\uff1a</p> <pre><code># 1\u30da\u30fc\u30b8\u76ee\n\n---\n\n# 2\u30da\u30fc\u30b8\u76ee\n</code></pre>"},{"location":"guide/add-slide/#4","title":"4. \u30d3\u30eb\u30c9\u3057\u3066\u78ba\u8a8d","text":"<pre><code>bash slides/scripts/build-local.sh\nuv run mkdocs serve\n</code></pre>"},{"location":"guide/add-slide/#_3","title":"\u753b\u50cf\u306e\u4f7f\u3044\u65b9","text":"<p>\u753b\u50cf\u306f <code>slides/src/slides/&lt;\u30d5\u30a9\u30eb\u30c0\u540d&gt;/images/</code> \u306b\u7f6e\u304d\u307e\u3059\u3002</p> <pre><code># \u30a4\u30f3\u30e9\u30a4\u30f3\u753b\u50cf\n![\u8aac\u660e](./images/example.png)\n\n# \u53f3\u5074\u306b\u80cc\u666f\u3068\u3057\u3066\u8868\u793a\uff08\u30c6\u30ad\u30b9\u30c8\u3068\u4e26\u3079\u308b\uff09\n![bg right:40% contain](./images/example.png)\n\n# drawio \u30d5\u30a1\u30a4\u30eb\u3092\u305d\u306e\u307e\u307e\u4f7f\u3046\n![bg right:60% contain](./images/diagram.drawio.svg)\n</code></pre> <p>drawio \u30d5\u30a1\u30a4\u30eb\u306f VS Code \u306e Draw.io Integration \u62e1\u5f35\u3067\u305d\u306e\u307e\u307e\u7de8\u96c6\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"guide/add-slide/#_4","title":"\u30c6\u30fc\u30de\u306e\u5909\u66f4","text":"<p><code>content.md</code> \u306e frontmatter \u3067 <code>theme:</code> \u3092\u5909\u66f4\u3057\u307e\u3059\uff1a</p> <pre><code>theme: blue-theme   # slides/src/themes/ \u4ee5\u4e0b\u306e CSS \u30d5\u30a1\u30a4\u30eb\u540d\uff08\u62e1\u5f35\u5b50\u306a\u3057\uff09\n</code></pre> <p>\u65b0\u3057\u3044\u30c6\u30fc\u30de\u3092\u8ffd\u52a0\u3059\u308b\u5834\u5408\u306f <code>slides/src/themes/</code> \u306b CSS \u30d5\u30a1\u30a4\u30eb\u3092\u8ffd\u52a0\u3057\u307e\u3059\u3002</p>"},{"location":"guide/setup/","title":"\u30bb\u30c3\u30c8\u30a2\u30c3\u30d7\u30ac\u30a4\u30c9","text":""},{"location":"guide/setup/#_2","title":"\u524d\u63d0\u6761\u4ef6","text":"\u30c4\u30fc\u30eb \u30d0\u30fc\u30b8\u30e7\u30f3 \u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u65b9\u6cd5 Python 3.12+ python.org uv \u6700\u65b0 <code>curl -LsSf https://astral.sh/uv/install.sh \\| sh</code> Node.js 20+ nodejs.org Git \u4efb\u610f git-scm.com <p>VS Code \u3092\u4f7f\u3046\u5834\u5408\u306f\u4ee5\u4e0b\u306e\u62e1\u5f35\u6a5f\u80fd\u3082\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u3057\u3066\u304f\u3060\u3055\u3044\uff1a</p> <ul> <li>Marp for VS Code (<code>marp-team.marp-vscode</code>) - \u30b9\u30e9\u30a4\u30c9\u306e\u30d7\u30ec\u30d3\u30e5\u30fc</li> <li>Draw.io Integration (<code>hediet.vscode-drawio</code>) - drawio \u56f3\u306e\u7de8\u96c6</li> </ul> <p>\u30ea\u30dd\u30b8\u30c8\u30ea\u3092\u958b\u304f\u3068 VS Code \u304c\u81ea\u52d5\u7684\u306b\u63a8\u5968\u62e1\u5f35\u6a5f\u80fd\u3068\u3057\u3066\u63d0\u6848\u3057\u307e\u3059\u3002</p>"},{"location":"guide/setup/#_3","title":"\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\u624b\u9806","text":"<pre><code># 1. \u30ea\u30dd\u30b8\u30c8\u30ea\u3092\u30af\u30ed\u30fc\u30f3\ngit clone &lt;your-repo-url&gt;\ncd &lt;repo-name&gt;\n\n# 2. Python \u4f9d\u5b58\u95a2\u4fc2\u3092\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\uff08MkDocs \u306a\u3069\uff09\nuv sync\n\n# 3. Node.js \u4f9d\u5b58\u95a2\u4fc2\u3092\u30a4\u30f3\u30b9\u30c8\u30fc\u30eb\uff08Marp CLI\uff09\nnpm ci\n</code></pre>"},{"location":"guide/setup/#_4","title":"\u30ed\u30fc\u30ab\u30eb\u30d7\u30ec\u30d3\u30e5\u30fc","text":"<pre><code># \u30b9\u30e9\u30a4\u30c9\u3092\u30d3\u30eb\u30c9\u3057\u3066 docs/slides/ \u306b\u914d\u7f6e\nbash slides/scripts/build-local.sh\n\n# \u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u30b5\u30a4\u30c8\u3092\u8d77\u52d5\nuv run mkdocs serve\n</code></pre> <p><code>http://localhost:8000</code> \u3067\u30b5\u30a4\u30c8\u304c\u78ba\u8a8d\u3067\u304d\u307e\u3059\u3002 \u30d5\u30a1\u30a4\u30eb\u3092\u4fdd\u5b58\u3059\u308b\u3068\u81ea\u52d5\u3067\u30ea\u30ed\u30fc\u30c9\u3055\u308c\u307e\u3059\u3002</p>"},{"location":"guide/setup/#github-pages","title":"GitHub Pages \u3078\u306e\u30c7\u30d7\u30ed\u30a4\u8a2d\u5b9a","text":"<ol> <li>GitHub \u30ea\u30dd\u30b8\u30c8\u30ea\u306e Settings \u2192 Pages \u3092\u958b\u304f</li> <li>Source \u3092 <code>Deploy from a branch</code> \u306b\u8a2d\u5b9a</li> <li>\u30d6\u30e9\u30f3\u30c1\u3092 <code>gh-pages</code>\u3001\u30d5\u30a9\u30eb\u30c0\u3092 <code>/ (root)</code> \u306b\u8a2d\u5b9a\u3057\u3066\u4fdd\u5b58</li> </ol> <p>\u8a2d\u5b9a\u5f8c\u306f <code>main</code> \u30d6\u30e9\u30f3\u30c1\u3078\u306e push \u3067\u81ea\u52d5\u30c7\u30d7\u30ed\u30a4\u3055\u308c\u307e\u3059\u3002</p>"},{"location":"slides/","title":"\u30b9\u30e9\u30a4\u30c9\u4e00\u89a7","text":"<ul> <li> <p> \u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u6d3b\u7528\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3092\u4f5c\u308d\u3046</p> <p>\ud83d\udcc5 2026-03-31</p> </li> </ul>"}]}